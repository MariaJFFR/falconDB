#!/bin/bash

ACTION=${1:-start}

case $ACTION in

  start)
    echo "cleaning logs"
    rm -f logs/*.log

    echo "starting RP"
    forever start src/reverseProxy/server.js

    sleep 2

    echo "starting DN0"
    forever start src/dataNode/dn0s1/server.js
    forever start src/dataNode/dn0s2/server.js
    forever start src/dataNode/dn0s3/server.js

    echo "starting DN1"
    forever start src/dataNode/dn1s1/server.js
    forever start src/dataNode/dn1s2/server.js
    forever start src/dataNode/dn1s3/server.js

    echo "starting DN2"
    forever start src/dataNode/dn2s1/server.js
    forever start src/dataNode/dn2s2/server.js
    forever start src/dataNode/dn2s3/server.js
    ;;

  stop)
    echo "stopping DN2"
    forever stop src/dataNode/dn2s3/server.js
    forever stop src/dataNode/dn2s2/server.js
    forever stop src/dataNode/dn2s1/server.js

    echo "stopping DN1"
    forever stop src/dataNode/dn1s3/server.js
    forever stop src/dataNode/dn1s2/server.js
    forever stop src/dataNode/dn1s1/server.js

    echo "stopping DN0"
    forever stop src/dataNode/dn0s3/server.js
    forever stop src/dataNode/dn0s2/server.js
    forever stop src/dataNode/dn0s1/server.js

    echo "stopping RP"
    forever stop src/reverseProxy/server.js
    ;;

  restart)
    $0 stop
    sleep 1
    $0 start
    ;;

  stat)
    forever list
    ;;

  *)
    echo "Usage: $0 {start|stop|restart|stat}"
    exit 1
    ;;

esac
